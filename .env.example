# Heard local development settings

APP_ENV=local
APP_PORT=8080

DATABASE_URL=postgres://heard:heard@localhost:5432/heard?sslmode=disable

# Provider mode should default to fake for local development.
SMS_PROVIDER=fake
EMAIL_PROVIDER=fake
AI_PROVIDER=fake

# Public URL used for local QR/link generation.
PUBLIC_APP_URL=http://localhost:8080
