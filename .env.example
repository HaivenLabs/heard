# Heard local development settings

APP_ENV=local
APP_PORT=8080
DATABASE_URL=postgres://heard:heard@localhost:5432/heard?sslmode=disable

# Browser-facing app URLs
PUBLIC_APP_URL=http://localhost:3010
WEB_BASE_URL=http://localhost:3010
ALLOWED_ORIGIN=http://localhost:3010

# qurl integration. Leave empty to disable QR asset generation.
QURL_BASE_URL=
HEARD_SEED_DEMO=true
WORKER_POLL_INTERVAL_MS=1500

# Frontend browser config
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_DEMO_TENANT_ID=11111111-1111-1111-1111-111111111111
